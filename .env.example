# Purpose: Example environment variables for local Docker, Unraid and CLI execution.
# Input/Output: Loaded by docker-compose or exported in the shell before running the CLI.
# Invariants: Secrets stay out of committed files; replace placeholders before production use.
# Debugging: If authentication fails, verify that the referenced environment variable names match the config.

OPENAI_API_KEY=replace-with-real-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4.1-mini
MISTRAL_BASE_URL=http://ollama-or-unraid-host:11434/v1
MISTRAL_MODEL_NAME=mistral-small3.2:latest
QWEN_BASE_URL=http://ollama-or-unraid-host:11434/v1
QWEN_MODEL_NAME=qwen3.5:35b-a3b
BENCHMARK_CONFIG=/config/config.unraid.example.yaml
BENCHMARK_AUTO_RUN=true
BENCHMARK_ACTION=dashboard
BENCHMARK_SUITE=quick_compare
BENCHMARK_TESTS_DIR=/app/tests
BENCHMARK_RESULTS_DIR=/app/results
BENCHMARK_DEBUG=false
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
RESULTS_DIR=/app/results
LOG_LEVEL=INFO
DEFAULT_TIMEOUT_SECONDS=300
